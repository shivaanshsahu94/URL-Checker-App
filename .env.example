# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# FEEDBACK_WEBHOOK_URL: The endpoint for submitting user feedback.
# This is injected at build time via the Secrets Gradle Plugin.
# Set the actual URL in your local .env file (not committed to source control).
FEEDBACK_WEBHOOK_URL=YOUR_WEBHOOK_URL_HERE
